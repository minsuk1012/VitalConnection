{
  "vars": {
    "bg-color": "#E8F4FD",
    "circle-size": "600px",
    "circle-top": "60px",
    "circle-border": "6px solid white",
    "tag-top": "30px",
    "tag-size": "18px",
    "tag-bg": "rgba(0,0,0,0.3)",
    "tag-text-color": "white",
    "banner-height": "280px",
    "banner-color": "#3B82F6",
    "headline-size": "70px",
    "price-size": "91px",
    "accent-color": "#FFD700",
    "text-color": "#ffffff",
    "brand-size": "19px",
    "headline-font": "Noto",
    "headline-style": "normal",
    "headline-letter-spacing": "0px",
    "headline-rotation": "0deg",
    "headline-max-width": "var(--headline-max-width, 900px)",
    "model-opacity": "1",
    "model-brightness": "1",
    "headline-z-index": "5",
    "headline-opacity": "1",
    "headline-line-height": "1.2"
  },
  "controls": [
    {
      "group": "폰트",
      "items": [
        {
          "var": "headline-font",
          "label": "헤드라인 폰트",
          "type": "select",
          "options": [
            {
              "value": "Noto",
              "label": "Noto Sans KR"
            },
            {
              "value": "Pretendard",
              "label": "Pretendard Bold"
            },
            {
              "value": "BlackHan",
              "label": "Black Han Sans"
            },
            {
              "value": "Bebas",
              "label": "Bebas Neue"
            },
            {
              "value": "Montserrat",
              "label": "Montserrat"
            },
            {
              "value": "Playfair",
              "label": "Playfair Display"
            },
            {
              "value": "PlayfairI",
              "label": "Playfair Italic"
            },
            {
              "value": "NotoSerif",
              "label": "Noto Serif"
            },
            {
              "value": "Anton",
              "label": "Anton (영문 임팩트)"
            },
            {
              "value": "Oswald",
              "label": "Oswald (영문 압축)"
            },
            {
              "value": "Cormorant",
              "label": "Cormorant (럭셔리 세리프)"
            },
            {
              "value": "NanumGothic",
              "label": "나눔고딕"
            },
            {
              "value": "GmarketSans",
              "label": "지마켓 산스 (트렌디)"
            },
            {
              "value": "NanumSquare",
              "label": "나눔스퀘어 (모던)"
            },
            {
              "value": "NanumRound",
              "label": "나눔스퀘어라운드 (부드러운)"
            }
          ]
        },
        {
          "var": "headline-style",
          "label": "기울이기",
          "type": "select",
          "options": [
            {
              "value": "normal",
              "label": "보통"
            },
            {
              "value": "italic",
              "label": "이탤릭"
            }
          ]
        },
        {
          "var": "headline-letter-spacing",
          "label": "자간",
          "type": "range",
          "min": -4,
          "max": 20,
          "unit": "px"
        }
      ]
    },
    {
      "group": "배경/원형",
      "items": [
        {
          "var": "bg-color",
          "label": "배경 색상",
          "type": "color"
        },
        {
          "var": "circle-size",
          "label": "원 크기",
          "type": "range",
          "min": 200,
          "max": 900,
          "unit": "px"
        },
        {
          "var": "circle-top",
          "label": "원 상단 여백",
          "type": "range",
          "min": 0,
          "max": 400,
          "unit": "px"
        }
      ]
    },
    {
      "group": "배너",
      "items": [
        {
          "var": "banner-height",
          "label": "배너 높이",
          "type": "range",
          "min": 100,
          "max": 500,
          "unit": "px"
        },
        {
          "var": "banner-color",
          "label": "배너 색상",
          "type": "color"
        }
      ]
    },
    {
      "group": "텍스트",
      "items": [
        {
          "var": "headline-size",
          "label": "헤드라인 크기",
          "type": "range",
          "min": 28,
          "max": 90,
          "unit": "px"
        },
        {
          "var": "price-size",
          "label": "가격 크기",
          "type": "range",
          "min": 36,
          "max": 120,
          "unit": "px"
        },
        {
          "var": "accent-color",
          "label": "가격 색상",
          "type": "color"
        }
      ]
    },
    {
      "group": "헤드라인 커스텀",
      "items": [
        {
          "var": "headline-rotation",
          "label": "회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "headline-max-width",
          "label": "최대 너비",
          "type": "range",
          "min": 100,
          "max": 1080,
          "unit": "px"
        },
        {
          "var": "headline-z-index",
          "label": "헤드라인 레이어",
          "type": "range",
          "min": 0,
          "max": 20,
          "unit": ""
        },
        {
          "var": "headline-opacity",
          "label": "헤드라인 불투명도",
          "type": "range",
          "min": 0,
          "max": 1,
          "unit": "",
          "step": 0.05
        },
        {
          "var": "headline-line-height",
          "label": "줄간격",
          "type": "range",
          "min": 0.8,
          "max": 2.5,
          "unit": "",
          "step": 0.05
        }
      ]
    },
    {
      "group": "모델",
      "items": [
        {
          "var": "model-opacity",
          "label": "모델 불투명도",
          "type": "range",
          "min": 0,
          "max": 1,
          "unit": "",
          "step": 0.05
        },
        {
          "var": "model-brightness",
          "label": "모델 밝기",
          "type": "range",
          "min": 0.3,
          "max": 2,
          "unit": "",
          "step": 0.05
        }
      ]
    }
  ],
  "layout": "bottom-banner-circle"
}