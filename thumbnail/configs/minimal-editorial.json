          "options": [
            {
              "value": "Noto",
              "label": "Noto Sans KR"
            },
            {
              "value": "Pretendard",
              "label": "Pretendard Bold"
            },
            {
              "value": "BlackHan",
              "label": "Black Han Sans"
            },
            {
              "value": "Bebas",
              "label": "Bebas Neue"
            },
            {
              "value": "Montserrat",
              "label": "Montserrat"
            },
            {
              "value": "Playfair",
              "label": "Playfair Display"
            },
            {
              "value": "PlayfairI",
              "label": "Playfair Italic"
            },
            {
              "value": "NotoSerif",
              "label": "Noto Serif"
            },
            {
              "value": "Anton",
              "label": "Anton (영문 임팩트)"
            },
            {
              "value": "Oswald",
              "label": "Oswald (영문 압축)"
            },
            {
              "value": "Cormorant",
              "label": "Cormorant (럭셔리 세리프)"
            },
            {
              "value": "NanumGothic",
              "label": "나눔고딕"
            },
            {
              "value": "GmarketSans",
              "label": "지마켓 산스 (트렌디)"
            },
            {
              "value": "NanumSquare",
              "label": "나눔스퀘어 (모던)"
            },
            {
              "value": "NanumRound",
              "label": "나눔스퀘어라운드 (부드러운)"
            }
          ]
        },
        {
          "var": "headline-style",
          "label": "기울이기",
          "type": "select",
          "options": [
            {
              "value": "normal",
              "label": "보통"
            },
            {
              "value": "italic",
              "label": "이탤릭"
            }
          ]
        },
        {
          "var": "headline-letter-spacing",
          "label": "자간",
          "type": "range",
          "min": -4,
          "max": 20,
          "unit": "px"
        }
      ]
    },
    {
      "group": "그라디언트",
      "items": [
        {
          "var": "gradient-start",
          "label": "시작 위치",
          "type": "range",
          "min": 0,
          "max": 100,
          "unit": "%"
        },
        {
          "var": "gradient-opacity",
          "label": "강도",
          "type": "range",
          "min": 0.1,
          "max": 0.9,
          "unit": "",
          "step": 0.05
        }
      ]
    },
    {
      "group": "액센트 라인",
      "items": [
        {
          "var": "accent-left",
          "label": "좌측 여백",
          "type": "range",
          "min": 0,
          "max": 200,
          "unit": "px"
        },
        {
          "var": "accent-top",
          "label": "상단 여백",
          "type": "range",
          "min": 20,
          "max": 400,
          "unit": "px"
        },
        {
          "var": "accent-width",
          "label": "두께",
          "type": "range",
          "min": 1,
          "max": 12,
          "unit": "px"
        },
        {
          "var": "accent-height",
          "label": "높이",
          "type": "range",
          "min": 20,
          "max": 200,
          "unit": "px"
        },
        {
          "var": "accent-color",
          "label": "색상",
          "type": "color"
        }
      ]
    },
    {
      "group": "헤드라인",
      "items": [
        {
          "var": "headline-left",
          "label": "좌측 여백",
          "type": "range",
          "min": 0,
          "max": 300,
          "unit": "px"
        },
        {
          "var": "headline-bottom",
          "label": "하단 여백",
          "type": "range",
          "min": 50,
          "max": 600,
          "unit": "px"
        },
        {
          "var": "headline-size",
          "label": "폰트 크기",
          "type": "range",
          "min": 36,
          "max": 120,
          "unit": "px"
        },
        {
          "var": "headline-line-height",
          "label": "줄 간격",
          "type": "range",
          "min": 0.8,
          "max": 2.0,
          "unit": "",
          "step": 0.05
        },
        {
          "var": "headline-color",
          "label": "색상",
          "type": "color"
        }
      ]
    },
    {
      "group": "브랜드",
      "items": [
        {
          "var": "brand-right",
          "label": "우측 여백",
          "type": "range",
          "min": 0,
          "max": 200,
          "unit": "px"
        },
        {
          "var": "brand-bottom",
          "label": "하단 여백",
          "type": "range",
          "min": 10,
          "max": 200,
          "unit": "px"
        },
        {
          "var": "brand-size",
          "label": "폰트 크기",
          "type": "range",
          "min": 10,
          "max": 36,
          "unit": "px"
        },
        {
          "var": "brand-opacity",
          "label": "투명도",
          "type": "range",
          "min": 0.1,
          "max": 1.0,
          "unit": "",
          "step": 0.05
        }
      ]
    },
    {
      "group": "헤드라인 커스텀",
      "items": [
        {
          "var": "headline-rotation",
          "label": "회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "headline-max-width",
          "label": "최대 너비",
          "type": "range",
          "min": 100,
          "max": 1080,
          "unit": "px"
        },
        {
          "var": "headline-z-index",
          "label": "헤드라인 레이어",
          "type": "range",
          "min": 0,
          "max": 20,
          "unit": ""
        },
        {
          "var": "headline-opacity",
          "label": "헤드라인 불투명도",
          "type": "range",
          "min": 0,
          "max": 1,
          "unit": "",
          "step": 0.05
        }
      ]
    },
    {
      "group": "모델",
      "items": [
        {
          "var": "model-opacity",
          "label": "모델 불투명도",
          "type": "range",
          "min": 0,
          "max": 1,
          "unit": "",
          "step": 0.05
        },
        {
          "var": "model-brightness",
          "label": "모델 밝기",
          "type": "range",
          "min": 0.3,
          "max": 2,
          "unit": "",
          "step": 0.05
        }
      ]
    }
  ]
