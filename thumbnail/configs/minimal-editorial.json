{
  "layout": "minimal-editorial",
  "vars": {
    "gradient-start": "50%",
    "gradient-opacity": "0.52",
    "accent-left": "32px",
    "accent-top": "80px",
    "accent-width": "3px",
    "accent-height": "64px",
    "accent-color": "#E8C4A0",
    "headline-left": "32px",
    "headline-bottom": "130px",
    "headline-size": "97px",
    "headline-color": "#ffffff",
    "headline-line-height": "1.1",
    "brand-right": "28px",
    "brand-bottom": "28px",
    "brand-size": "33px",
    "brand-opacity": "0.75",
    "headline-font": "Noto",
    "headline-style": "normal",
    "headline-letter-spacing": "0px",
    "headline-rotation": "0deg",
    "headline-max-width": "600px",
    "model-opacity": "1",
    "model-brightness": "1",
    "headline-z-index": "5",
