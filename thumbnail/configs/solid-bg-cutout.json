    {
      "group": "브랜드",
      "items": [
        {
          "var": "brand-left",
          "label": "좌측 여백",
          "type": "range",
          "min": 0,
          "max": 800,
          "unit": "px"
        },
        {
          "var": "brand-bottom",
          "label": "하단 여백",
          "type": "range",
          "min": 10,
          "max": 300,
          "unit": "px"
        },
        {
          "var": "brand-size",
          "label": "폰트 크기",
          "type": "range",
          "min": 10,
          "max": 40,
          "unit": "px"
        },
        {
          "var": "brand-color",
          "label": "색상",
          "type": "color"
        }
      ]
    },
    {
      "group": "헤드라인 커스텀",
      "items": [
        {
          "var": "headline-rotation",
          "label": "회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "headline-max-width",
          "label": "최대 너비",
          "type": "range",
          "min": 100,
          "max": 1080,
          "unit": "px"
        },
        {
          "var": "headline-z-index",
          "label": "헤드라인 레이어",
          "type": "range",
          "min": 0,
          "max": 20,
          "unit": ""
        },
        {
          "var": "headline-opacity",
          "label": "헤드라인 불투명도",
          "type": "range",
          "min": 0,
          "max": 1,
          "unit": "",
          "step": 0.05
        }
      ]
    },
    {
      "group": "서브헤드라인 커스텀",
      "items": [
        {
          "var": "sub-rotation",
          "label": "서브헤드 회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        }
      ]
    }
  ]
}