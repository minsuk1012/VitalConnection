{
  "layout": "solid-bg-cutout",
  "vars": {
    "bg-gradient": "linear-gradient(135deg, #FFBDCD 0%, #FFD6E0 100%)",
    "model-right": "-20px",
    "model-bottom": "0px",
    "model-width": "60%",
    "text-left": "20px",
    "text-max-width": "1000px",
    "sub-top": "40px",
    "sub-size": "36px",
    "sub-color": "#fff",
    "headline-top": "90px",
    "headline-size": "160px",
    "headline-color": "#ffffff",
    "headline-line-height": "1.0",
    "text-shadow": "0 4px 15px rgba(0,0,0,0.2)",
    "price-top": "600px",
    "price-size": "160px",
    "price-color": "#ffffff",
    "badge-left": "20px",
    "badge-bottom": "60px",
    "badge-size": "180px",
    "badge-bg": "rgba(255,255,255,0.9)",
    "badge-border": "3px solid rgba(255,255,255,0.6)",
    "badge-color": "#FF6B9D",
    "brand-left": "36px",
    "brand-bottom": "32px",
    "brand-size": "22px",
    "brand-color": "rgba(255,255,255,0.75)",
    "sparkle-color": "#ffffff",
    "sparkle-size": "32px",
    "headline-font": "Noto",
    "headline-style": "normal",
    "headline-letter-spacing": "0px",
    "headline-rotation": "0deg",
    "headline-max-width": "var(--text-max-width)",
    "sub-rotation": "0deg",
    "sub-margin-top": "0px",
    "headline-z-index": "5",
    "headline-opacity": "1"
