        {
          "var": "headline-font",
          "label": "헤드라인 폰트",
          "type": "select",
          "options": [
            {
              "value": "Noto",
              "label": "Noto Sans KR"
            },
            {
              "value": "Pretendard",
              "label": "Pretendard Bold"
            },
            {
              "value": "BlackHan",
              "label": "Black Han Sans"
            },
            {
              "value": "Bebas",
              "label": "Bebas Neue"
            },
            {
              "value": "Montserrat",
              "label": "Montserrat"
            },
            {
              "value": "Playfair",
              "label": "Playfair Display"
            },
            {
              "value": "PlayfairI",
              "label": "Playfair Italic"
            },
            {
              "value": "NotoSerif",
              "label": "Noto Serif"
            },
            {
              "value": "Anton",
              "label": "Anton (영문 임팩트)"
            },
            {
              "value": "Oswald",
              "label": "Oswald (영문 압축)"
            },
            {
              "value": "Cormorant",
              "label": "Cormorant (럭셔리 세리프)"
            },
            {
              "value": "NanumGothic",
              "label": "나눔고딕"
            },
            {
              "value": "GmarketSans",
              "label": "지마켓 산스 (트렌디)"
            },
            {
              "value": "NanumSquare",
              "label": "나눔스퀘어 (모던)"
            },
            {
              "value": "NanumRound",
              "label": "나눔스퀘어라운드 (부드러운)"
            }
          ]
        },
        {
          "var": "headline-style",
          "label": "기울이기",
          "type": "select",
          "options": [
            {
              "value": "normal",
              "label": "보통"
            },
            {
              "value": "italic",
              "label": "이탤릭"
            }
          ]
        },
        {
          "var": "headline-letter-spacing",
          "label": "자간",
          "type": "range",
          "min": -4,
          "max": 20,
          "unit": "px"
        }
      ]
    },
    {
      "group": "배경",
      "items": [
        {
          "var": "bg-gradient",
          "label": "배경 색상/그라디언트",
          "type": "color"
        }
      ]
    },
    {
      "group": "모델 위치",
      "items": [
        {
          "var": "model-width",
          "label": "모델 크기",
          "type": "range",
          "min": 0,
          "max": 100,
          "unit": "%"
        },
        {
          "var": "model-right",
          "label": "우측 여백",
          "type": "range",
          "min": -300,
          "max": 300,
          "unit": "px"
        },
        {
          "var": "model-bottom",
          "label": "하단 여백",
          "type": "range",
          "min": -200,
          "max": 400,
          "unit": "px"
        }
      ]
    },
    {
      "group": "헤드라인",
      "items": [
        {
          "var": "text-left",
          "label": "좌측 여백",
          "type": "range",
          "min": 0,
          "max": 500,
          "unit": "px"
        },
        {
          "var": "headline-top",
          "label": "상단 여백",
          "type": "range",
          "min": 0,
          "max": 700,
          "unit": "px"
        },
        {
          "var": "headline-size",
          "label": "폰트 크기",
          "type": "range",
          "min": 36,
          "max": 140,
          "unit": "px"
        },
        {
          "var": "headline-color",
          "label": "색상",
          "type": "color"
        },
        {
          "var": "headline-line-height",
          "label": "줄 간격",
          "type": "range",
          "min": 0.8,
          "max": 2.0,
          "unit": "",
          "step": 0.05
        },
        {
          "var": "text-max-width",
          "label": "최대 너비",
          "type": "range",
          "min": 100,
          "max": 900,
          "unit": "px"
        }
      ]
    },
    {
      "group": "가격 (인라인)",
      "items": [
        {
          "var": "price-top",
          "label": "상단 여백",
          "type": "range",
          "min": 0,
          "max": 900,
          "unit": "px"
        },
        {
          "var": "price-size",
          "label": "폰트 크기",
          "type": "range",
          "min": 40,
          "max": 180,
          "unit": "px"
        },
        {
          "var": "price-color",
          "label": "색상",
          "type": "color"
        }
      ]
    },
    {
      "group": "원형 배지",
      "items": [
        {
          "var": "badge-left",
          "label": "좌측 여백",
          "type": "range",
          "min": 0,
          "max": 800,
          "unit": "px"
        },
        {
          "var": "badge-bottom",
          "label": "하단 여백",
          "type": "range",
          "min": 0,
          "max": 800,
          "unit": "px"
        },
        {
          "var": "badge-size",
          "label": "배지 크기",
          "type": "range",
          "min": 60,
          "max": 300,
          "unit": "px"
        },
        {
          "var": "badge-bg",
          "label": "배지 배경",
          "type": "color"
        },
        {
          "var": "badge-color",
          "label": "배지 텍스트",
          "type": "color"
        }
      ]
    },
    {
      "group": "장식",
      "items": [
        {
          "var": "sparkle-color",
          "label": "반짝이 색상",
          "type": "color"
        },
        {
          "var": "sparkle-size",
          "label": "반짝이 크기",
          "type": "range",
          "min": 10,
          "max": 80,
          "unit": "px"
        }
      ]
