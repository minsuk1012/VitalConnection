{
  "vars": {
    "bg-color": "#0A0A0A",
    "body-pad": "64px",
    "text-color": "#ffffff",
    "accent-color": "#FF6B9D",
    "bg-number-color": "#ffffff",
    "sub-size": "25px",
    "headline-size": "130px",
    "price-size": "182px",
    "brand-right": "40px",
    "brand-bottom": "40px",
    "brand-size": "22px",
    "headline-font": "Noto",
    "headline-style": "normal",
    "headline-letter-spacing": "0px",
    "headline-rotation": "0deg",
    "headline-max-width": "var(--headline-max-width, 900px)",
    "sub-rotation": "0deg",
    "sub-margin-top": "0px",
    "headline-z-index": "5",
    "headline-opacity": "1"
  },
  "controls": [
    {
      "group": "폰트",
      "items": [
        {
          "var": "headline-font",
          "label": "헤드라인 폰트",
          "type": "select",
          "options": [
            {
              "value": "Noto",
              "label": "Noto Sans KR"
            },
            {
              "value": "Pretendard",
              "label": "Pretendard Bold"
            },
            {
              "value": "BlackHan",
              "label": "Black Han Sans"
            },
            {
              "value": "Bebas",
              "label": "Bebas Neue"
            },
            {
              "value": "Montserrat",
              "label": "Montserrat"
            },
            {
              "value": "Playfair",
              "label": "Playfair Display"
            },
            {
              "value": "PlayfairI",
              "label": "Playfair Italic"
            },
            {
              "value": "NotoSerif",
              "label": "Noto Serif"
            },
            {
              "value": "Anton",
              "label": "Anton (영문 임팩트)"
            },
            {
              "value": "Oswald",
              "label": "Oswald (영문 압축)"
            },
            {
              "value": "Cormorant",
              "label": "Cormorant (럭셔리 세리프)"
            },
            {
              "value": "NanumGothic",
              "label": "나눔고딕"
            },
            {
              "value": "GmarketSans",
              "label": "지마켓 산스 (트렌디)"
            },
            {
              "value": "NanumSquare",
              "label": "나눔스퀘어 (모던)"
            },
            {
              "value": "NanumRound",
              "label": "나눔스퀘어라운드 (부드러운)"
            }
          ]
        },
        {
          "var": "headline-style",
          "label": "기울이기",
          "type": "select",
          "options": [
            {
              "value": "normal",
              "label": "보통"
            },
            {
              "value": "italic",
              "label": "이탤릭"
            }
          ]
        },
        {
          "var": "headline-letter-spacing",
          "label": "자간",
          "type": "range",
          "min": -4,
          "max": 20,
          "unit": "px"
        }
      ]
    },
    {
      "group": "배경",
      "items": [
        {
          "var": "bg-color",
          "label": "배경 색상",
          "type": "color"
        },
        {
          "var": "body-pad",
          "label": "내부 여백",
          "type": "range",
          "min": 20,
          "max": 120,
          "unit": "px"
        }
      ]
    },
    {
      "group": "타이포",
      "items": [
        {
          "var": "text-color",
          "label": "텍스트 색상",
          "type": "color"
        },
        {
          "var": "headline-size",
          "label": "헤드라인 크기",
          "type": "range",
          "min": 36,
          "max": 160,
          "unit": "px"
        },
        {
          "var": "sub-size",
          "label": "서브 크기",
          "type": "range",
          "min": 14,
          "max": 48,
          "unit": "px"
        },
        {
          "var": "accent-color",
          "label": "가격 색상",
          "type": "color"
        },
        {
          "var": "price-size",
          "label": "가격 크기",
          "type": "range",
          "min": 60,
          "max": 200,
          "unit": "px"
        }
      ]
    },
    {
      "group": "헤드라인 커스텀",
      "items": [
        {
          "var": "headline-rotation",
          "label": "회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "headline-max-width",
          "label": "최대 너비",
          "type": "range",
          "min": 100,
          "max": 1080,
          "unit": "px"
        },
        {
          "var": "headline-z-index",
          "label": "헤드라인 레이어",
          "type": "range",
          "min": 0,
          "max": 20,
          "unit": ""
        },
        {
          "var": "headline-opacity",
          "label": "헤드라인 불투명도",
          "type": "range",
          "min": 0,
          "max": 1,
          "unit": "",
          "step": 0.05
        }
      ]
    },
    {
      "group": "서브헤드라인 커스텀",
      "items": [
        {
          "var": "sub-rotation",
          "label": "서브헤드 회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "sub-margin-top",
          "label": "서브헤드 위 여백",
          "type": "range",
          "min": 0,
          "max": 200,
          "unit": "px"
        }
      ]
    }
  ],
  "layout": "text-only-bold"
}