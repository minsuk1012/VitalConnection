{
  "layout": "gradient-dark-spotlight",
  "vars": {
    "bg-dark": "#0B0C10",
    "spotlight-color": "#E94560",
    "spotlight-size": "1200px",
    "spotlight-x": "-200px",
    "spotlight-y": "-100px",
    "spotlight-opacity": "0.6",
    "model-right": "-40px",
    "model-bottom": "0px",
    "model-width": "75%",
    "text-top": "120px",
    "text-left": "60px",
    "headline-font": "Noto",
    "headline-size": "140px",
    "headline-color": "#FFFFFF",
    "headline-letter-spacing": "-1px",
    "sub-size": "36px",
    "sub-color": "#FFFFFF",
    "price-size": "150px",
    "price-color": "#FFFFFF",
    "headline-rotation": "0deg",
    "headline-max-width": "var(--text-max-width, 700px)",
    "sub-rotation": "0deg",
    "sub-margin-top": "0px",
    "headline-z-index": "5",
    "headline-opacity": "1"
  },
  "controls": [
    {
      "group": "배경 및 조명",
      "items": [
        {
          "var": "bg-dark",
          "label": "배경 어두운 톤",
          "type": "color"
        },
        {
          "var": "spotlight-color",
          "label": "조명(스팟라이트) 색상",
          "type": "color"
        },
        {
          "var": "spotlight-size",
          "label": "조명 크기",
          "type": "range",
          "min": 500,
          "max": 2000,
          "unit": "px"
        },
        {
          "var": "spotlight-opacity",
          "label": "조명 세기",
          "type": "range",
          "min": 0.1,
          "max": 1.0,
          "step": 0.05,
          "unit": ""
        },
        {
          "var": "spotlight-x",
          "label": "가로 위치",
          "type": "range",
          "min": -1000,
          "max": 1000,
          "unit": "px"
        },
        {
          "var": "spotlight-y",
          "label": "세로 위치",
          "type": "range",
          "min": -1000,
          "max": 1000,
          "unit": "px"
        }
      ]
    },
    {
      "group": "폰트",
      "items": [
        {
          "var": "headline-font",
          "label": "헤드라인 폰트",
          "type": "select",
          "options": [
            {
              "value": "Noto",
              "label": "Noto Sans KR"
            },
            {
              "value": "Pretendard",
              "label": "Pretendard Bold"
            },
            {
              "value": "BlackHan",
              "label": "Black Han Sans"
            },
            {
              "value": "Anton",
              "label": "Anton (영문 임팩트)"
            },
            {
              "value": "Oswald",
              "label": "Oswald (영문 압축)"
            },
            {
              "value": "Cormorant",
              "label": "Cormorant (럭셔리 세리프)"
            },
            {
              "value": "NanumGothic",
              "label": "나눔고딕"
            },
            {
              "value": "GmarketSans",
              "label": "지마켓 산스 (트렌디)"
            },
            {
              "value": "NanumSquare",
              "label": "나눔스퀘어 (모던)"
            },
            {
              "value": "NanumRound",
              "label": "나눔스퀘어라운드 (부드러운)"
            }
          ]
        }
      ]
    },
    {
      "group": "텍스트 색상",
      "items": [
        {
          "var": "headline-color",
          "label": "제목 색상",
          "type": "color"
        },
        {
          "var": "sub-color",
          "label": "서브 색상",
          "type": "color"
        },
        {
          "var": "price-color",
          "label": "가격 색상",
          "type": "color"
        }
      ]
    },
    {
      "group": "헤드라인 커스텀",
      "items": [
        {
          "var": "headline-rotation",
          "label": "회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "headline-max-width",
          "label": "최대 너비",
          "type": "range",
          "min": 100,
          "max": 1080,
          "unit": "px"
        },
        {
          "var": "headline-z-index",
          "label": "헤드라인 레이어",
          "type": "range",
          "min": 0,
          "max": 20,
          "unit": ""
        },
        {
          "var": "headline-opacity",
          "label": "헤드라인 불투명도",
          "type": "range",
          "min": 0,
          "max": 1,
          "unit": "",
          "step": 0.05
        }
      ]
    },
    {
      "group": "서브헤드라인 커스텀",
      "items": [
        {
          "var": "sub-rotation",
          "label": "서브헤드 회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "sub-margin-top",
          "label": "서브헤드 위 여백",
          "type": "range",
          "min": 0,
          "max": 200,
          "unit": "px"
        }
      ]
    }
  ]
}