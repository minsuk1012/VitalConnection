{
  "layout": "solid-bg-stacked",
  "vars": {
    "bg-color": "#F5A623",
    "model-width": "620px",
    "fade-stop": "42%",
    "text-left": "36px",
    "text-top": "80px",
    "stack-gap": "12px",
    "brand-size": "24px",
    "brand-img-size": "22px",
    "text-color": "#1A1A1A",
    "sub-size": "22px",
    "headline-size": "76px",
    "headline-line-height": "1.12",
    "text-max-width": "480px",
    "price-label-size": "16px",
    "price-size": "104px",
    "accent-color": "#1A1A1A",
    "headline-font": "Noto",
    "headline-style": "normal",
    "headline-letter-spacing": "0px",
    "headline-rotation": "0deg",
    "headline-max-width": "var(--text-max-width)",
    "sub-rotation": "0deg",
    "sub-margin-top": "0px",
    "model-opacity": "1",
    "model-brightness": "1",
    "headline-z-index": "5",
    "headline-opacity": "1"
  },
  "controls": [
    {
      "group": "폰트",
      "items": [
        {
          "var": "headline-font",
          "label": "헤드라인 폰트",
          "type": "select",
          "options": [
            {
              "value": "Noto",
              "label": "Noto Sans KR"
            },
            {
              "value": "Pretendard",
              "label": "Pretendard Bold"
            },
            {
              "value": "BlackHan",
              "label": "Black Han Sans"
            },
            {
              "value": "Bebas",
              "label": "Bebas Neue"
            },
            {
              "value": "Montserrat",
              "label": "Montserrat"
            },
            {
              "value": "Playfair",
              "label": "Playfair Display"
            },
            {
              "value": "PlayfairI",
              "label": "Playfair Italic"
            },
            {
              "value": "NotoSerif",
              "label": "Noto Serif"
            },
            {
              "value": "Anton",
              "label": "Anton (영문 임팩트)"
            },
            {
              "value": "Oswald",
              "label": "Oswald (영문 압축)"
            },
            {
              "value": "Cormorant",
              "label": "Cormorant (럭셔리 세리프)"
            },
            {
              "value": "NanumGothic",
              "label": "나눔고딕"
            },
            {
              "value": "GmarketSans",
              "label": "지마켓 산스 (트렌디)"
            },
            {
              "value": "NanumSquare",
              "label": "나눔스퀘어 (모던)"
            },
            {
              "value": "NanumRound",
              "label": "나눔스퀘어라운드 (부드러운)"
            }
          ]
        },
        {
          "var": "headline-style",
          "label": "기울이기",
          "type": "select",
          "options": [
            {
              "value": "normal",
              "label": "보통"
            },
            {
              "value": "italic",
              "label": "이탤릭"
            }
          ]
        },
        {
          "var": "headline-letter-spacing",
          "label": "자간",
          "type": "range",
          "min": -4,
          "max": 20,
          "unit": "px"
        }
      ]
    },
    {
      "group": "배경/모델",
      "items": [
        {
          "var": "bg-color",
          "label": "배경 색상",
          "type": "color"
        },
        {
          "var": "model-width",
          "label": "모델 너비",
          "type": "range",
          "min": 200,
          "max": 900,
          "unit": "px"
        },
        {
          "var": "fade-stop",
          "label": "페이드 끝 지점",
          "type": "range",
          "min": 0,
          "max": 100,
          "unit": "%"
        }
      ]
    },
    {
      "group": "텍스트",
      "items": [
        {
          "var": "text-left",
          "label": "좌측 여백",
          "type": "range",
          "min": 0,
          "max": 300,
          "unit": "px"
        },
        {
          "var": "text-top",
          "label": "상단 여백",
          "type": "range",
          "min": 0,
          "max": 400,
          "unit": "px"
        },
        {
          "var": "stack-gap",
          "label": "요소 간격",
          "type": "range",
          "min": 4,
          "max": 40,
          "unit": "px"
        },
        {
          "var": "text-color",
          "label": "텍스트 색상",
          "type": "color"
        }
      ]
    },
    {
      "group": "헤드라인",
      "items": [
        {
          "var": "headline-size",
          "label": "폰트 크기",
          "type": "range",
          "min": 28,
          "max": 100,
          "unit": "px"
        },
        {
          "var": "headline-line-height",
          "label": "줄 간격",
          "type": "range",
          "min": 0.8,
          "max": 2.0,
          "unit": "",
          "step": 0.05
        },
        {
          "var": "text-max-width",
          "label": "최대 너비",
          "type": "range",
          "min": 100,
          "max": 800,
          "unit": "px"
        }
      ]
    },
    {
      "group": "가격",
      "items": [
        {
          "var": "price-size",
          "label": "폰트 크기",
          "type": "range",
          "min": 40,
          "max": 140,
          "unit": "px"
        },
        {
          "var": "accent-color",
          "label": "가격 색상",
          "type": "color"
        }
      ]
    },
    {
      "group": "헤드라인 커스텀",
      "items": [
        {
          "var": "headline-rotation",
          "label": "회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "headline-max-width",
          "label": "최대 너비",
          "type": "range",
          "min": 100,
          "max": 1080,
          "unit": "px"
        },
        {
          "var": "headline-z-index",
          "label": "헤드라인 레이어",
          "type": "range",
          "min": 0,
          "max": 20,
          "unit": ""
        },
        {
          "var": "headline-opacity",
          "label": "헤드라인 불투명도",
          "type": "range",
          "min": 0,
          "max": 1,
          "unit": "",
          "step": 0.05
        }
      ]
    },
    {
      "group": "서브헤드라인 커스텀",
      "items": [
        {
          "var": "sub-rotation",
          "label": "서브헤드 회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "sub-margin-top",
          "label": "서브헤드 위 여백",
          "type": "range",
          "min": 0,
          "max": 200,
          "unit": "px"
        }
      ]
    },
    {
      "group": "모델",
      "items": [
        {
          "var": "model-opacity",
          "label": "모델 불투명도",
          "type": "range",
          "min": 0,
          "max": 1,
          "unit": "",
          "step": 0.05
        },
        {
          "var": "model-brightness",
          "label": "모델 밝기",
          "type": "range",
          "min": 0.3,
          "max": 2,
          "unit": "",
          "step": 0.05
        }
      ]
    }
  ]
}