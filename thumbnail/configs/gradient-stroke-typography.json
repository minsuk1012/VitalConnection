{
  "layout": "gradient-stroke-typography",
  "vars": {
    "bg-color": "#FFFFFF",
    "gradient-line": "linear-gradient(45deg, #FF9A9E 0%, #FECFEF 99%, #FECFEF 100%)",
    "frame-margin": "40px",
    "frame-width": "8px",
    "text-gradient": "linear-gradient(45deg, #FF6B9D 0%, #FF9A9E 100%)",
    "model-right": "-50px",
    "model-bottom": "0px",
    "model-width": "65%",
    "text-top": "180px",
    "text-left": "80px",
    "headline-font": "Noto",
    "headline-size": "130px",
    "headline-letter-spacing": "-1px",
    "sub-size": "36px",
    "sub-color": "#666666",
    "price-size": "120px",
    "price-color": "#333333",
    "brand-color": "#999999",
    "headline-rotation": "0deg",
    "headline-max-width": "var(--text-max-width, 700px)",
    "sub-rotation": "0deg",
    "sub-margin-top": "0px",
    "headline-z-index": "5",
    "headline-opacity": "1"
  },
  "controls": [
    {
      "group": "배경 및 효과",
      "items": [
        {
          "var": "bg-color",
          "label": "배경 단색",
          "type": "color"
        },
        {
          "var": "gradient-line",
          "label": "테두리 그라디언트",
          "type": "color"
        },
        {
          "var": "text-gradient",
          "label": "글자 그라디언트",
          "type": "color"
        },
        {
          "var": "frame-width",
          "label": "테두리 두께",
          "type": "range",
          "min": 0,
          "max": 40,
          "unit": "px"
        }
      ]
    },
    {
      "group": "텍스트",
      "items": [
        {
          "var": "headline-font",
          "label": "헤드라인 폰트",
          "type": "select",
          "options": [
            {
              "value": "Noto",
              "label": "Noto Sans KR"
            },
            {
              "value": "Pretendard",
              "label": "Pretendard Bold"
            },
            {
              "value": "BlackHan",
              "label": "Black Han Sans"
            },
            {
              "value": "Anton",
              "label": "Anton (영문 임팩트)"
            },
            {
              "value": "Oswald",
              "label": "Oswald (영문 압축)"
            },
            {
              "value": "Cormorant",
              "label": "Cormorant (럭셔리 세리프)"
            },
            {
              "value": "NanumGothic",
              "label": "나눔고딕"
            },
            {
              "value": "GmarketSans",
              "label": "지마켓 산스 (트렌디)"
            },
            {
              "value": "NanumSquare",
              "label": "나눔스퀘어 (모던)"
            },
            {
              "value": "NanumRound",
              "label": "나눔스퀘어라운드 (부드러운)"
            }
          ]
        },
        {
          "var": "sub-color",
          "label": "서브헤드 색상",
          "type": "color"
        },
        {
          "var": "price-color",
          "label": "가격 색상",
          "type": "color"
        }
      ]
    },
    {
      "group": "헤드라인 커스텀",
      "items": [
        {
          "var": "headline-rotation",
          "label": "회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "headline-max-width",
          "label": "최대 너비",
          "type": "range",
          "min": 100,
          "max": 1080,
          "unit": "px"
        },
        {
          "var": "headline-z-index",
          "label": "헤드라인 레이어",
          "type": "range",
          "min": 0,
          "max": 20,
          "unit": ""
        },
        {
          "var": "headline-opacity",
          "label": "헤드라인 불투명도",
          "type": "range",
          "min": 0,
          "max": 1,
          "unit": "",
          "step": 0.05
        }
      ]
    },
    {
      "group": "서브헤드라인 커스텀",
      "items": [
        {
          "var": "sub-rotation",
          "label": "서브헤드 회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "sub-margin-top",
          "label": "서브헤드 위 여백",
          "type": "range",
          "min": 0,
          "max": 200,
          "unit": "px"
        }
      ]
    }
  ]
}