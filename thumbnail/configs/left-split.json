        {
          "var": "brand-size",
          "label": "폰트 크기",
          "type": "range",
          "min": 12,
          "max": 40,
          "unit": "px"
        },
        {
          "var": "brand-color",
          "label": "색상",
          "type": "color"
        }
      ]
    },
    {
      "group": "액센트 바",
      "items": [
        {
          "var": "accent-left",
          "label": "좌측 여백",
          "type": "range",
          "min": 0,
          "max": 300,
          "unit": "px"
        },
        {
          "var": "accent-bottom",
          "label": "하단 여백",
          "type": "range",
          "min": 50,
          "max": 400,
          "unit": "px"
