{
  "layout": "diagonal-split",
  "vars": {
    "panel-left-y": "65%",
    "panel-right-y": "38%",
    "panel-color": "#2C1A0E",
    "panel-opacity": "0.6",
    "panel-blur": "12px",
    "accent-color": "rgba(255,255,255,0.35)",
    "text-left": "32px",
    "text-top": "470px",
    "sub-size": "20px",
    "sub-opacity": "0.75",
    "tag-size": "17px",
    "tag-opacity": "0.55",
    "divider-opacity": "0.25",
    "badge-size": "15px",
    "headline-size": "92px",
    "headline-line-height": "1.05",
    "brand-size": "19px",
    "brand-opacity": "0.6",
    "headline-font": "Noto",
    "headline-style": "normal",
    "headline-letter-spacing": "0px",
    "headline-rotation": "0deg",
    "headline-max-width": "var(--headline-max-width, 900px)",
    "sub-rotation": "0deg",
    "sub-margin-top": "0px",
    "tagline-rotation": "0deg",
    "model-opacity": "1",
    "model-brightness": "1",
    "headline-z-index": "5",
    "headline-opacity": "1"
  },
  "controls": [
    {
      "group": "폰트",
      "items": [
        {
          "var": "headline-font",
          "label": "헤드라인 폰트",
          "type": "select",
          "options": [
            {
              "value": "Noto",
              "label": "Noto Sans KR"
            },
            {
              "value": "Pretendard",
              "label": "Pretendard Bold"
            },
            {
              "value": "BlackHan",
              "label": "Black Han Sans"
            },
            {
              "value": "Bebas",
              "label": "Bebas Neue"
            },
            {
              "value": "Montserrat",
              "label": "Montserrat"
            },
            {
              "value": "Playfair",
              "label": "Playfair Display"
            },
            {
              "value": "PlayfairI",
              "label": "Playfair Italic"
            },
            {
              "value": "NotoSerif",
              "label": "Noto Serif"
            },
            {
              "value": "Anton",
              "label": "Anton (영문 임팩트)"
            },
            {
              "value": "Oswald",
              "label": "Oswald (영문 압축)"
            },
            {
              "value": "Cormorant",
              "label": "Cormorant (럭셔리 세리프)"
            },
            {
              "value": "NanumGothic",
              "label": "나눔고딕"
            },
            {
              "value": "GmarketSans",
              "label": "지마켓 산스 (트렌디)"
            },
            {
              "value": "NanumSquare",
              "label": "나눔스퀘어 (모던)"
            },
            {
              "value": "NanumRound",
              "label": "나눔스퀘어라운드 (부드러운)"
            }
          ]
        },
        {
          "var": "headline-style",
          "label": "기울이기",
          "type": "select",
          "options": [
            {
              "value": "normal",
              "label": "보통"
            },
            {
              "value": "italic",
              "label": "이탤릭"
            }
          ]
        },
        {
          "var": "headline-letter-spacing",
          "label": "자간",
          "type": "range",
          "min": -4,
          "max": 20,
          "unit": "px"
        }
      ]
    },
    {
      "group": "대각선 패널",
      "items": [
        {
          "var": "panel-left-y",
          "label": "좌측 시작 Y",
          "type": "range",
          "min": 0,
          "max": 100,
          "unit": "%"
        },
        {
          "var": "panel-right-y",
          "label": "우측 시작 Y",
          "type": "range",
          "min": 0,
          "max": 100,
          "unit": "%"
        },
        {
          "var": "panel-color",
          "label": "패널 색상",
          "type": "color"
        },
        {
          "var": "panel-opacity",
          "label": "대각선 패널 투명도",
          "type": "range",
          "min": 0.1,
          "max": 1.0,
          "unit": "",
          "step": 0.05
        },
        {
          "var": "panel-blur",
          "label": "글래스모피즘(블러)",
          "type": "range",
          "min": 0,
          "max": 30,
          "unit": "px"
        },
        {
          "var": "accent-color",
          "label": "포인트 평행선 색상",
          "type": "color"
        }
      ]
    },
    {
      "group": "텍스트 영역",
      "items": [
        {
          "var": "text-left",
          "label": "좌측 여백",
          "type": "range",
          "min": 0,
          "max": 200,
          "unit": "px"
        },
        {
          "var": "text-top",
          "label": "상단 위치",
          "type": "range",
          "min": 300,
          "max": 800,
          "unit": "px"
        }
      ]
    },
    {
      "group": "헤드라인",
      "items": [
        {
          "var": "headline-size",
          "label": "폰트 크기",
          "type": "range",
          "min": 30,
          "max": 100,
          "unit": "px"
        },
        {
          "var": "headline-line-height",
          "label": "줄 간격",
          "type": "range",
          "min": 0.8,
          "max": 1.8,
          "unit": "",
          "step": 0.05
        }
      ]
    },
    {
      "group": "기타",
      "items": [
        {
          "var": "badge-size",
          "label": "배지 폰트",
          "type": "range",
          "min": 10,
          "max": 24,
          "unit": "px"
        },
        {
          "var": "brand-size",
          "label": "브랜드 폰트",
          "type": "range",
          "min": 10,
          "max": 28,
          "unit": "px"
        },
        {
          "var": "brand-opacity",
          "label": "브랜드 투명도",
          "type": "range",
          "min": 0.1,
          "max": 1.0,
          "unit": "",
          "step": 0.05
        }
      ]
    },
    {
      "group": "헤드라인 커스텀",
      "items": [
        {
          "var": "headline-rotation",
          "label": "회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "headline-max-width",
          "label": "최대 너비",
          "type": "range",
          "min": 100,
          "max": 1080,
          "unit": "px"
        },
        {
          "var": "headline-z-index",
          "label": "헤드라인 레이어",
          "type": "range",
          "min": 0,
          "max": 20,
          "unit": ""
        },
        {
          "var": "headline-opacity",
          "label": "헤드라인 불투명도",
          "type": "range",
          "min": 0,
          "max": 1,
          "unit": "",
          "step": 0.05
        }
      ]
    },
    {
      "group": "서브헤드라인 커스텀",
      "items": [
        {
          "var": "sub-rotation",
          "label": "서브헤드 회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "sub-margin-top",
          "label": "서브헤드 위 여백",
          "type": "range",
          "min": 0,
          "max": 200,
          "unit": "px"
        }
      ]
    },
    {
      "group": "태그라인 커스텀",
      "items": [
        {
          "var": "tagline-rotation",
          "label": "태그라인 회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        }
      ]
    },
    {
      "group": "모델",
      "items": [
        {
          "var": "model-opacity",
          "label": "모델 불투명도",
          "type": "range",
          "min": 0,
          "max": 1,
          "unit": "",
          "step": 0.05
        },
        {
          "var": "model-brightness",
          "label": "모델 밝기",
          "type": "range",
          "min": 0.3,
          "max": 2,
          "unit": "",
          "step": 0.05
        }
      ]
    }
  ]
}