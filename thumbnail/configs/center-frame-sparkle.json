{
  "layout": "center-frame-sparkle",
  "vars": {
    "bg-color": "#FFDFBA",
    "text-color": "#111111",
    "headline-size": "150px",
    "stroke-width": "16px",
    "stroke-color": "#ffffff",
    "brand-stroke-width": "10px",
    "headline-font": "NotoSerif",
    "brand-font": "NotoSerif",
    "headline-letter-spacing": "-2px",
    "headline-rotation": "0deg",
    "headline-max-width": "var(--headline-max-width, 900px)",
    "model-opacity": "1",
    "model-brightness": "1",
    "headline-z-index": "5",
    "headline-opacity": "1"
  },
  "controls": [
