{
  "layout": "gradient-glassmorphism",
  "vars": {
    "bg-gradient": "linear-gradient(120deg, #A1C4FD 0%, #C2E9FB 100%)",
    "model-right": "-40px",
    "model-bottom": "0px",
    "model-width": "75%",
    "card-x": "60px",
    "card-y": "160px",
    "card-width": "700px",
    "card-padding": "60px 50px",
    "glass-bg": "rgba(255, 255, 255, 0.4)",
    "glass-blur": "30px",
    "glass-border-width": "2px",
    "glass-border-color": "rgba(255, 255, 255, 0.5)",
    "glass-shadow": "0 16px 40px rgba(0, 0, 0, 0.1)",
    "glass-divider": "rgba(255, 255, 255, 0.5)",
    "text-gap": "20px",
    "headline-font": "Pretendard",
    "headline-size": "120px",
    "headline-color": "#1A1A1A",
    "headline-line-height": "1.2",
    "headline-letter-spacing": "-2px",
    "sub-size": "36px",
    "sub-color": "#333333",
    "price-size": "130px",
    "price-color": "#0052FF",
    "price-mt": "30px",
    "brand-top": "60px",
    "brand-right": "60px",
    "brand-size": "24px",
    "brand-color": "#FFFFFF",
    "headline-rotation": "0deg",
    "headline-max-width": "100%",
    "sub-rotation": "0deg",
    "sub-margin-top": "0px",
    "headline-z-index": "5",
    "headline-opacity": "1"
  },
  "controls": [
    {
      "group": "배경",
      "items": [
        {
          "var": "bg-gradient",
          "label": "그라디언트 CSS",
          "type": "color"
        }
      ]
    },
    {
      "group": "폰트",
      "items": [
        {
          "var": "headline-font",
          "label": "헤드라인 폰트",
          "type": "select",
          "options": [
            {
              "value": "Noto",
              "label": "Noto Sans KR"
            },
            {
              "value": "Pretendard",
              "label": "Pretendard Bold"
            },
            {
              "value": "BlackHan",
              "label": "Black Han Sans"
            },
            {
              "value": "Anton",
              "label": "Anton (영문 임팩트)"
            },
            {
              "value": "Oswald",
              "label": "Oswald (영문 압축)"
            },
            {
              "value": "Cormorant",
              "label": "Cormorant (럭셔리 세리프)"
            },
            {
              "value": "NanumGothic",
              "label": "나눔고딕"
            },
            {
              "value": "GmarketSans",
              "label": "지마켓 산스 (트렌디)"
            },
            {
              "value": "NanumSquare",
              "label": "나눔스퀘어 (모던)"
            },
            {
              "value": "NanumRound",
              "label": "나눔스퀘어라운드 (부드러운)"
            }
          ]
        }
      ]
    },
    {
      "group": "글래스 효과 카드",
      "items": [
        {
          "var": "card-x",
          "label": "가로 위치",
          "type": "range",
          "min": 0,
          "max": 500,
          "unit": "px"
        },
        {
          "var": "card-y",
          "label": "세로 위치",
          "type": "range",
          "min": 0,
          "max": 500,
          "unit": "px"
        },
        {
          "var": "glass-bg",
          "label": "카드 배경색",
          "type": "color"
        },
        {
          "var": "glass-blur",
          "label": "블러 강도",
          "type": "range",
          "min": 0,
          "max": 100,
          "unit": "px"
        }
      ]
    },
    {
      "group": "텍스트",
      "items": [
        {
          "var": "headline-color",
          "label": "제목 색상",
          "type": "color"
        },
        {
          "var": "sub-color",
          "label": "서브 색상",
          "type": "color"
        },
        {
          "var": "price-color",
          "label": "가격 색상",
          "type": "color"
        }
      ]
    },
    {
      "group": "헤드라인 커스텀",
      "items": [
        {
          "var": "headline-rotation",
          "label": "회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "headline-max-width",
          "label": "최대 너비",
          "type": "range",
          "min": 100,
          "max": 1080,
          "unit": "px"
        },
        {
          "var": "headline-z-index",
          "label": "헤드라인 레이어",
          "type": "range",
          "min": 0,
          "max": 20,
          "unit": ""
        },
        {
          "var": "headline-opacity",
          "label": "헤드라인 불투명도",
          "type": "range",
          "min": 0,
          "max": 1,
          "unit": "",
          "step": 0.05
        }
      ]
    },
    {
      "group": "서브헤드라인 커스텀",
      "items": [
        {
          "var": "sub-rotation",
          "label": "서브헤드 회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "sub-margin-top",
          "label": "서브헤드 위 여백",
          "type": "range",
          "min": 0,
          "max": 200,
          "unit": "px"
        }
      ]
    }
  ]
}