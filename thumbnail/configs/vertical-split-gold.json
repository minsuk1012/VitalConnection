{
  "layout": "vertical-split-gold",
  "vars": {
    "panel-color": "#F5F0E6",
    "frame-base-color": "#D4AF37",
    "text-color": "#111111",
    "accent-color": "#C29367",
    "headline-size": "160px",
    "price-size": "130px",
    "headline-rotation": "0deg",
    "headline-max-width": "var(--headline-max-width, 900px)",
    "sub-rotation": "0deg",
    "sub-margin-top": "0px",
    "model-opacity": "1",
    "model-brightness": "1",
    "headline-z-index": "5",
    "headline-opacity": "1"
  },
  "controls": [
    {
      "group": "색상",
      "items": [
        {
          "var": "panel-color",
          "label": "측면 패널/가격표 배경",
          "type": "color"
        },
        {
          "var": "text-color",
          "label": "기본 텍스트 및 테두리 색",
          "type": "color"
        },
        {
          "var": "accent-color",
          "label": "세로 헤드라인 색상",
          "type": "color"
        },
        {
          "var": "frame-base-color",
          "label": "프레임 색상 (메탈 코팅 자동적용)",
          "type": "color"
        }
      ]
    },
    {
      "group": "크기",
      "items": [
        {
          "var": "headline-size",
          "label": "헤드라인 크기 (세로)",
          "type": "range",
          "min": 80,
          "max": 250,
          "unit": "px"
        },
        {
          "var": "price-size",
          "label": "가격 크기",
          "type": "range",
          "min": 60,
          "max": 200,
          "unit": "px"
        }
      ]
    },
    {
      "group": "헤드라인 커스텀",
      "items": [
        {
          "var": "headline-rotation",
          "label": "회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "headline-max-width",
          "label": "최대 너비",
          "type": "range",
          "min": 100,
          "max": 1080,
          "unit": "px"
        },
        {
          "var": "headline-z-index",
          "label": "헤드라인 레이어",
          "type": "range",
          "min": 0,
          "max": 20,
          "unit": ""
        },
        {
          "var": "headline-opacity",
          "label": "헤드라인 불투명도",
          "type": "range",
          "min": 0,
          "max": 1,
          "unit": "",
          "step": 0.05
        }
      ]
    },
    {
      "group": "서브헤드라인 커스텀",
      "items": [
        {
          "var": "sub-rotation",
          "label": "서브헤드 회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "sub-margin-top",
          "label": "서브헤드 위 여백",
          "type": "range",
          "min": 0,
          "max": 200,
          "unit": "px"
        }
      ]
    },
    {
      "group": "모델",
      "items": [
        {
          "var": "model-opacity",
          "label": "모델 불투명도",
          "type": "range",
          "min": 0,
          "max": 1,
          "unit": "",
          "step": 0.05
        },
        {
          "var": "model-brightness",
          "label": "모델 밝기",
          "type": "range",
          "min": 0.3,
          "max": 2,
          "unit": "",
          "step": 0.05
        }
      ]
    }
  ]
}