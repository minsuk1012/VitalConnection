{
  "layout": "full-overlay-gradient",
  "vars": {
    "overlay-color": "#000000",
    "overlay-width": "45%",
    "overlay-opacity": "0.82",
    "text-left": "36px",
    "brand-top": "36px",
    "brand-size": "36px",
    "sub-top": "200px",
    "sub-size": "21px",
    "headline-top": "260px",
    "headline-size": "86px",
    "headline-line-height": "1.1",
    "price-top": "520px",
    "price-size": "114px",
    "accent-color": "#ffffff",
    "headline-rotation": "0deg",
    "headline-max-width": "var(--headline-max-width, 900px)",
    "sub-rotation": "0deg",
    "sub-margin-top": "0px",
    "model-opacity": "1",
    "model-brightness": "1",
    "headline-z-index": "5",
    "headline-opacity": "1"
  },
  "controls": [
    {
      "group": "컬러 오버레이",
      "items": [
        {
          "var": "overlay-color",
          "label": "오버레이 색상",
          "type": "color"
        },
        {
          "var": "overlay-width",
          "label": "오버레이 너비",
          "type": "range",
          "min": 0,
          "max": 100,
          "unit": "%"
        },
        {
          "var": "overlay-opacity",
          "label": "불투명도",
          "type": "range",
          "min": 0.3,
          "max": 1,
          "unit": "",
          "step": 0.05
        }
      ]
    },
    {
      "group": "텍스트 위치",
      "items": [
        {
          "var": "text-left",
          "label": "좌측 여백",
          "type": "range",
          "min": 0,
          "max": 200,
          "unit": "px"
        },
        {
          "var": "brand-top",
          "label": "브랜드 Y",
          "type": "range",
          "min": 10,
          "max": 200,
          "unit": "px"
        },
        {
          "var": "sub-top",
          "label": "서브헤드 Y",
          "type": "range",
          "min": 80,
          "max": 500,
          "unit": "px"
        },
        {
          "var": "headline-top",
          "label": "헤드라인 Y",
          "type": "range",
          "min": 100,
          "max": 600,
          "unit": "px"
        },
        {
          "var": "price-top",
          "label": "가격 Y",
          "type": "range",
          "min": 200,
          "max": 800,
          "unit": "px"
        }
      ]
    },
    {
      "group": "폰트",
      "items": [
        {
          "var": "headline-size",
          "label": "헤드라인 크기",
          "type": "range",
          "min": 32,
          "max": 100,
          "unit": "px"
        },
        {
          "var": "headline-line-height",
          "label": "줄 간격",
          "type": "range",
          "min": 0.8,
          "max": 1.8,
          "unit": "",
          "step": 0.05
        },
        {
          "var": "price-size",
          "label": "가격 크기",
          "type": "range",
          "min": 40,
          "max": 140,
          "unit": "px"
        },
        {
          "var": "accent-color",
          "label": "가격 색상",
          "type": "color"
        }
      ]
    },
    {
      "group": "헤드라인 커스텀",
      "items": [
        {
          "var": "headline-rotation",
          "label": "회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "headline-max-width",
          "label": "최대 너비",
          "type": "range",
          "min": 100,
          "max": 1080,
          "unit": "px"
        },
        {
          "var": "headline-z-index",
          "label": "헤드라인 레이어",
          "type": "range",
          "min": 0,
          "max": 20,
          "unit": ""
        },
        {
          "var": "headline-opacity",
          "label": "헤드라인 불투명도",
          "type": "range",
          "min": 0,
          "max": 1,
          "unit": "",
          "step": 0.05
        }
      ]
    },
    {
      "group": "서브헤드라인 커스텀",
      "items": [
        {
          "var": "sub-rotation",
          "label": "서브헤드 회전",
          "type": "range",
          "min": -45,
          "max": 45,
          "unit": "deg",
          "step": 1
        },
        {
          "var": "sub-margin-top",
          "label": "서브헤드 위 여백",
          "type": "range",
          "min": 0,
          "max": 200,
          "unit": "px"
        }
      ]
    },
    {
      "group": "모델",
      "items": [
        {
          "var": "model-opacity",
          "label": "모델 불투명도",
          "type": "range",
          "min": 0,
          "max": 1,
          "unit": "",
          "step": 0.05
        },
        {
          "var": "model-brightness",
          "label": "모델 밝기",
          "type": "range",
          "min": 0.3,
          "max": 2,
          "unit": "",
          "step": 0.05
        }
      ]
    }
  ]
}